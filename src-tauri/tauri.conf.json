{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "fidget-toy",
  "version": "0.1.3",
  "identifier": "com.teun.fidget-toy",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Fidget Toy",
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "shadow": false,
        "maximized": true,
        "focus": false
      },
      {
        "label": "settings",
        "url": "settings.html",
        "title": "Fidget Toy Settings",
        "width": 380,
        "height": 620,
        "resizable": true,
        "decorations": true,
        "minimizable": true,
        "maximizable": false,
        "closable": true,
        "visible": false,
        "skipTaskbar": false
      }
    ],
    "macOSPrivateApi": true,
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/tvanboxtel/fidget-toy/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDIxQTQxNDVCRUFGODlFRjIKUldUeW52anFXeFNrSVFlQ1VnOUlDMjBibEVPY0MrUEQvOGZQaGhaZDE0Q2o4NGdTNzcxalZ0bmgK"
    }
  }
}
